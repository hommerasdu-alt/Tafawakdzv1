# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PDF CDN URL: The base URL where your PDF files are hosted.
VITE_PDF_CDN_URL="https://cdn.tafawak.dz/pdfs/ar"

# GitHub Database Integration
# Repository in format: username/repo-name
VITE_GITHUB_REPO=""
# Branch to fetch from (default: main)
VITE_GITHUB_BRANCH="main"

# SQL Server Configuration
DB_SERVER=172.0.0.1
DB_NAME=tafawakdz
DB_USER=
DB_PASSWORD=
DB_ENCRYPT=false

# App Configuration
PORT=3000
NODE_ENV=development

# Supabase Configuration
# Obtenez ces informations dans Paramètres > API de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://ecjleikavlsiqyazbbvt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-publique
SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-role-secrete

